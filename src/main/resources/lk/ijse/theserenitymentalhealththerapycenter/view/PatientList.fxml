<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.PatientListController"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="20" style="-fx-padding: 28;">
        <!-- Edit Form -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <Label text="✏️  Edit Patient" style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Separator/>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="FULL NAME" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEditName" promptText="Patient name"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="EMAIL" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEditEmail" promptText="Email"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="PHONE" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEditPhone" promptText="Phone"/>
                </VBox>
            </HBox>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="ADDRESS" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEditAddress" promptText="Address"/>
                </VBox>
            </HBox>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="✏️  Update" onAction="#handleUpdatePatient" styleClass="btn-primary" style="-fx-padding: 10 24;"/>
                <Button text="🔄  Clear" onAction="#handleClearEditForm" styleClass="btn-secondary"/>
            </HBox>
        </VBox>

        <!-- Patient Table -->
        <VBox spacing="0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 20 16 20;">
                <Label text="🧑‍🤝‍🧑  Patient Records" style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtSearchPatient" promptText="🔍  Search..." prefWidth="220" style="-fx-background-color: #F5F0EB; -fx-border-color: transparent; -fx-background-radius: 10; -fx-padding: 8 12; -fx-font-size: 12px;"/>
                <Button text="🗑  Delete" onAction="#handleDeletePatient" style="-fx-background-color: #C47171; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 10; -fx-cursor: hand;"/>
            </HBox>
            <Separator/>
            <TableView fx:id="tblPatients" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colPatientId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colPatientName" text="Name" prefWidth="180"/>
                    <TableColumn fx:id="colPatientEmail" text="Email" prefWidth="180"/>
                    <TableColumn fx:id="colPatientPhone" text="Phone" prefWidth="130"/>
                    <TableColumn fx:id="colPatientAddress" text="Address" prefWidth="180"/>
                    <TableColumn fx:id="colPatientDate" text="Registered" prefWidth="110"/>
                </columns>
                <placeholder><Label text="No patients found." style="-fx-text-fill: #95A5A6; -fx-font-size: 13px;"/></placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
