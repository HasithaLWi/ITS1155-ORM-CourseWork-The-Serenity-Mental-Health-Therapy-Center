<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<HBox prefHeight="800" prefWidth="1280" style="-fx-background-color: linear-gradient(to bottom right, #FAF8F5, #F0ECE6);" stylesheets="@calm-clarity.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.RegistrationController">

    <!-- ═══════════ LEFT BRANDING PANEL ═══════════ -->
    <VBox alignment="CENTER" spacing="12" style="-fx-background-color: rgba(139,175,158,0.08); -fx-min-width: 480;" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="60" left="60" right="60" top="60" />
        </padding>

        <StackPane maxHeight="120" maxWidth="120">
            <Circle radius="60" style="-fx-fill: rgba(107,157,194,0.1); -fx-stroke: rgba(107,157,194,0.2); -fx-stroke-width: 2;" />
            <Circle radius="40" style="-fx-fill: rgba(139,175,158,0.15); -fx-stroke: rgba(139,175,158,0.25); -fx-stroke-width: 1;" />
            <Label style="-fx-font-size: 48px;" text="🌿" />
        </StackPane>

        <Region prefHeight="16" />

        <Label style="-fx-text-fill: #2D3436; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="Serenity" />
        <Label style="-fx-text-fill: #636E72; -fx-font-size: 16px; -fx-font-family: 'Segoe UI';" text="Mental Health Therapy Center" />

        <Region prefHeight="24" />

        <Separator maxWidth="200" style="-fx-background-color: #E5DFD8;" />

        <Region prefHeight="12" />

        <Label alignment="CENTER" maxWidth="300" style="-fx-text-fill: #8BAF9E; -fx-font-size: 13px; -fx-font-style: italic; -fx-font-family: 'Segoe UI';" text="Join our team and make a difference." wrapText="true" />

        <Label alignment="CENTER" maxWidth="300" style="-fx-text-fill: #95A5A6; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';" text="Create your account to get started." wrapText="true" />
    </VBox>

    <!-- ═══════════ RIGHT REGISTRATION PANEL ═══════════ -->
    <VBox alignment="CENTER" style="-fx-min-width: 560;" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="20" left="60" right="60" top="20" />
        </padding>

        <!-- Registration Card -->
        <VBox alignment="CENTER" maxWidth="460" spacing="4" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5DFD8; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.08), 20, 0, 0, 6);">
            <padding>
                <Insets bottom="28" left="40" right="40" top="32" />
            </padding>

            <!-- Header -->
            <Label style="-fx-text-fill: #2D3436; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="Create Reception Account" />
            <Label style="-fx-text-fill: #95A5A6; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';" text="Fill in your details to register" />

            <Region prefHeight="16" />

            <!-- Scrollable form area -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="520" vbarPolicy="AS_NEEDED">
                <VBox spacing="3">
                    <padding>
                        <Insets bottom="4" left="4" right="8" top="4" />
                    </padding>

                    <!-- Full Name -->
                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="FULL NAME" />
                    <TextField fx:id="txtFullName" promptText="Enter your full name" />
                    <Label fx:id="lblFullNameError" style="-fx-font-size: 10px;" text="" />

                    <!-- Email -->
                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="EMAIL" />
                    <TextField fx:id="txtEmail" promptText="Enter your email address" />
                    <Label fx:id="lblEmailError" style="-fx-font-size: 10px;" text="" />

                    <!-- Username -->
                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="USERNAME" />
                    <TextField fx:id="txtUsername" promptText="Choose a username" />
                    <Label fx:id="lblUsernameError" style="-fx-font-size: 10px;" text="" />

                    <!-- Password row -->
                    <HBox spacing="12">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="PASSWORD" />
                            <PasswordField fx:id="txtPassword" promptText="Min 6 characters" />
                            <Label fx:id="lblPasswordError" style="-fx-font-size: 10px;" text="" />
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="CONFIRM PASSWORD" />
                            <PasswordField fx:id="txtConfirmPassword" promptText="Repeat password" />
                            <Label fx:id="lblConfirmPasswordError" style="-fx-font-size: 10px;" text="" />
                        </VBox>
                    </HBox>

                    <Region prefHeight="4" />
                    <Separator />
                    <Region prefHeight="2" />
                    <Label fx:id="lblSecurityQuestionError" style="-fx-font-size: 10px;" text="" />

                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="AUTHENTICATION CODE" />
                    <TextField fx:id="textAuthentication" promptText="Enter Youer Authentication Code" />
                    <Label fx:id="lblAuthenticationInfo" style="-fx-font-size: 11px; -fx-text-fill: #8BAF9E;" text="Contact Admin to get Code" />
               <Label fx:id="lblAuthenticationError" layoutX="14.0" layoutY="410.0" style="-fx-font-size: 10px;" text="" />
                </VBox>
            </ScrollPane>

            <Region prefHeight="6" />

            <!-- Message -->
            <Label fx:id="lblMessage" alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 12px; -fx-font-family: 'Segoe UI';" text="" wrapText="true" />

            <!-- Register Button -->
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleRegister" styleClass="btn-primary" text="Create Account" />

            <Region prefHeight="10" />

            <!-- Back to Login -->
            <HBox alignment="CENTER" spacing="4">
                <Label style="-fx-text-fill: #95A5A6; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';" text="Already have an account?" />
                <Hyperlink onAction="#handleBackToLogin" style="-fx-text-fill: #4A7FA5; -fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: transparent;" text="Sign In" />
            </HBox>
        </VBox>
    </VBox>
</HBox>
