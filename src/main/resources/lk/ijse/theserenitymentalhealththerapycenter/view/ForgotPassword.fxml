<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.ForgotPasswordController"
      stylesheets="@calm-clarity.css"
      style="-fx-background-color: linear-gradient(to bottom right, #FAF8F5, #F0ECE6);"
      prefWidth="1280" prefHeight="800">

    <!-- ═══════════ LEFT BRANDING PANEL ═══════════ -->
    <VBox alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS"
          style="-fx-background-color: rgba(139,175,158,0.08); -fx-min-width: 480;">
        <padding>
            <Insets top="60" right="60" bottom="60" left="60"/>
        </padding>

        <!-- Decorative circles -->
        <StackPane maxWidth="120" maxHeight="120">
            <Circle radius="60" style="-fx-fill: rgba(107,157,194,0.1); -fx-stroke: rgba(107,157,194,0.2); -fx-stroke-width: 2;"/>
            <Circle radius="40" style="-fx-fill: rgba(139,175,158,0.15); -fx-stroke: rgba(139,175,158,0.25); -fx-stroke-width: 1;"/>
            <Label text="🔐" style="-fx-font-size: 42px;"/>
        </StackPane>

        <Region prefHeight="16"/>

        <Label text="Serenity"
               style="-fx-text-fill: #2D3436; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
        <Label text="Mental Health Therapy Center"
               style="-fx-text-fill: #636E72; -fx-font-size: 16px; -fx-font-family: 'Segoe UI';"/>

        <Region prefHeight="24"/>

        <Separator style="-fx-background-color: #E5DFD8;" maxWidth="200"/>

        <Region prefHeight="12"/>

        <Label text="Don't worry, we'll help you recover access."
               style="-fx-text-fill: #8BAF9E; -fx-font-size: 13px; -fx-font-style: italic; -fx-font-family: 'Segoe UI';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>

        <Label text="Your security is our priority."
               style="-fx-text-fill: #95A5A6; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>
    </VBox>

    <!-- ═══════════ RIGHT RESET PANEL ═══════════ -->
    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-min-width: 520;">
        <padding>
            <Insets top="40" right="80" bottom="40" left="80"/>
        </padding>

        <!-- Reset Card -->
        <VBox alignment="CENTER" spacing="6" maxWidth="420"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5DFD8; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.08), 20, 0, 0, 6);">
            <padding>
                <Insets top="40" right="44" bottom="36" left="44"/>
            </padding>

            <!-- Header -->
            <Label text="Reset Password"
                   style="-fx-text-fill: #2D3436; -fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
            <Label text="Follow the steps to recover your account"
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 13px; -fx-font-family: 'Segoe UI';"/>

            <Region prefHeight="12"/>

            <!-- Step indicators -->
            <HBox alignment="CENTER" spacing="24">
                <Label fx:id="step1Indicator" text="1"
                       style="-fx-text-fill: #4A7FA5; -fx-font-size: 28px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                <Label text="─" style="-fx-text-fill: #E5DFD8; -fx-font-size: 18px;"/>
                <Label fx:id="step2Indicator" text="2"
                       style="-fx-text-fill: #95A5A6; -fx-font-size: 28px; -fx-font-family: 'Segoe UI';"/>
                <Label text="─" style="-fx-text-fill: #E5DFD8; -fx-font-size: 18px;"/>
                <Label fx:id="step3Indicator" text="3"
                       style="-fx-text-fill: #95A5A6; -fx-font-size: 28px; -fx-font-family: 'Segoe UI';"/>
            </HBox>

            <Region prefHeight="16"/>
            <Separator/>
            <Region prefHeight="12"/>

            <!-- ═══ STEP 1: Identity Verification ═══ -->
            <VBox fx:id="step1Pane" spacing="6">
                <Label text="Step 1: Verify Your Identity"
                       style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

                <Region prefHeight="8"/>

                <Label text="USERNAME"
                       style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"
                       alignment="CENTER_LEFT" maxWidth="Infinity"/>
                <TextField fx:id="txtUsername" promptText="Enter your username"/>

                <Region prefHeight="4"/>

                <Label text="EMAIL ADDRESS"
                       style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"
                       alignment="CENTER_LEFT" maxWidth="Infinity"/>
                <TextField fx:id="txtEmail" promptText="Enter your email address"/>

                <Region prefHeight="4"/>

                <Label fx:id="lblStep1Error" text=""
                       style="-fx-text-fill: #C47171; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"
                       wrapText="true" maxWidth="Infinity" alignment="CENTER"/>

                <Region prefHeight="4"/>

                <Button text="Verify Identity" onAction="#handleVerifyIdentity" maxWidth="Infinity"
                        mnemonicParsing="false" styleClass="btn-primary"/>
            </VBox>

            <!-- ═══ STEP 2: Security Question ═══ -->
            <VBox fx:id="step2Pane" spacing="6" visible="false" managed="false">
                <Label text="Step 2: Security Question"
                       style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

                <Region prefHeight="8"/>

                <Label fx:id="lblSecurityQuestion" text=""
                       style="-fx-text-fill: #636E72; -fx-font-size: 13px; -fx-font-family: 'Segoe UI';"
                       wrapText="true" maxWidth="Infinity"/>

                <TextField fx:id="txtSecurityAnswer" promptText="Your answer"/>

                <Region prefHeight="4"/>

                <Label fx:id="lblStep2Error" text=""
                       style="-fx-text-fill: #C47171; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"
                       wrapText="true" maxWidth="Infinity" alignment="CENTER"/>

                <Region prefHeight="4"/>

                <HBox spacing="10">
                    <Button text="← Back" onAction="#handleBackToStep1"
                            styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="Verify Answer" onAction="#handleVerifyAnswer"
                            styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>

            <!-- ═══ STEP 3: New Password ═══ -->
            <VBox fx:id="step3Pane" spacing="6" visible="false" managed="false">
                <Label text="Step 3: Set New Password"
                       style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

                <Region prefHeight="8"/>

                <Label text="NEW PASSWORD"
                       style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"
                       alignment="CENTER_LEFT" maxWidth="Infinity"/>
                <PasswordField fx:id="txtNewPassword" promptText="Min 6 characters"/>

                <Region prefHeight="4"/>

                <Label text="CONFIRM PASSWORD"
                       style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"
                       alignment="CENTER_LEFT" maxWidth="Infinity"/>
                <PasswordField fx:id="txtConfirmNewPassword" promptText="Repeat new password"/>

                <Region prefHeight="4"/>

                <Label fx:id="lblStep3Error" text=""
                       style="-fx-text-fill: #C47171; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"
                       wrapText="true" maxWidth="Infinity" alignment="CENTER"/>

                <Region prefHeight="4"/>

                <Button text="Reset Password" onAction="#handleResetPassword" maxWidth="Infinity"
                        mnemonicParsing="false" styleClass="btn-primary"/>
            </VBox>

            <Region prefHeight="12"/>

            <Separator/>

            <Region prefHeight="8"/>

            <!-- Back to Login -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Remember your password?"
                       style="-fx-text-fill: #95A5A6; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';"/>
                <Hyperlink text="Sign In" onAction="#handleBackToLogin"
                           style="-fx-text-fill: #4A7FA5; -fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: transparent;"/>
            </HBox>

            <Region prefHeight="4"/>

            <Label text="© 2025 Serenity Therapy Center"
                   style="-fx-text-fill: #B8B0A6; -fx-font-size: 9px; -fx-font-family: 'Segoe UI';"/>
        </VBox>
    </VBox>
</HBox>
