<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.PatientRegistrationController">
    <VBox spacing="20" style="-fx-padding: 28;">
        <!-- Registration Form -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <Label style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;" text="➕  Register New Patient" />
            <Separator />
             <VBox spacing="4">
                 <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="FULL NAME *" />
                 <TextField fx:id="txtPatientName" promptText="Enter patient name" />
             </VBox>
         <HBox alignment="CENTER" layoutX="35.0" layoutY="772.0" spacing="10">
            <children>
                   <VBox spacing="4" HBox.hgrow="ALWAYS">
                       <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="EMAIL" />
                       <TextField fx:id="txtPatientEmail" promptText="Email address" />
                   </VBox>
                   <VBox spacing="4" HBox.hgrow="ALWAYS">
                       <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="PHONE" />
                       <TextField fx:id="txtPatientPhone" promptText="Phone number" />
                   </VBox>
            </children>
         </HBox>
             <VBox spacing="4">
                 <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="ADDRESS" />
                 <TextField fx:id="txtPatientAddress" promptText="Address" />
             </VBox>
         <VBox layoutX="35.0" layoutY="251.0" spacing="4">
            <children>
               <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="INTERVIEW NOTE" />
               <TextArea fx:id="txtInterviewNote" promptText="Note Here" wrapText="true">
                  <cursor>
                     <Cursor fx:constant="TEXT" />
                  </cursor>
               </TextArea>
            </children>
         </VBox>
            <VBox spacing="4">
                <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="THERAPY PROGRAM" />
            <HBox alignment="CENTER_RIGHT" spacing="10">
               <children>
                      <ComboBox fx:id="cmbPatientProgram" maxWidth="Infinity" promptText="Select therapy program to enroll" HBox.hgrow="ALWAYS" />
                  <Button styleClass="btn-secondary" text="+  Add" />
               </children>
            </HBox>
            </VBox>
         <VBox layoutX="35.0" layoutY="519.0" spacing="4">
            <children>
               <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="SELECTED PROGRAM" />
               <TableView prefHeight="100.0" VBox.vgrow="ALWAYS">
                 <columns>
                   <TableColumn prefWidth="323.0" text="THERAPY PROGRAM" />
                     <TableColumn prefWidth="96.0" text="UPFRONT" />
                     <TableColumn prefWidth="56.0" text="ACTION" />
                 </columns>
                  <columnResizePolicy>
                     <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                  </columnResizePolicy>
               </TableView>
            </children>
         </VBox>
         <HBox alignment="CENTER_LEFT" layoutX="35.0" layoutY="604.0" spacing="10">
            <children>
               <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="UPFRONT PAYMENT" />
               <Label layoutX="389.0" layoutY="10.0" style="-fx-text-fill: #4A7FA5; -fx-font-size: 12px; -fx-font-weight: bold;" text="PENDING..." />
               <Region HBox.hgrow="ALWAYS" />
               <Label layoutX="118.0" layoutY="15.0" style="-fx-text-fill: black; -fx-font-size: 12px; -fx-font-weight: bold;" text="Rs 0.00" />
               <Button styleClass="btn-secondary" text="🔄  PAY" />
            </children>
         </HBox>
            <Label fx:id="lblRegMessage" style="-fx-font-size: 12px;" text="" wrapText="true" />
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#handleRegisterPatient" style="-fx-padding: 10 24;" styleClass="btn-primary" text="💾  Register Patient" />
                <Button onAction="#handleClearPatientForm" styleClass="btn-secondary" text="🔄  Clear" />
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
