<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.LoginController"
      style="-fx-background-color: linear-gradient(to bottom right, #0A1628, #1A2B4A);"
      prefWidth="1280" prefHeight="800">

    <!-- ═══════════ LEFT BRANDING PANEL ═══════════ -->
    <VBox alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS"
          style="-fx-background-color: rgba(255,255,255,0.03); -fx-min-width: 520;">
        <padding>
            <Insets top="60" right="60" bottom="60" left="60"/>
        </padding>

        <!-- Decorative circles -->
        <StackPane maxWidth="120" maxHeight="120">
            <Circle radius="60" style="-fx-fill: rgba(46,109,164,0.15); -fx-stroke: rgba(46,109,164,0.3); -fx-stroke-width: 2;"/>
            <Circle radius="40" style="-fx-fill: rgba(46,109,164,0.25); -fx-stroke: rgba(46,109,164,0.4); -fx-stroke-width: 1;"/>
            <Label text="🌿" style="-fx-font-size: 48px;"/>
        </StackPane>

        <Region prefHeight="16"/>

        <Label text="Serenity"
               style="-fx-text-fill: #FFFFFF; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
        <Label text="Mental Health Therapy Center"
               style="-fx-text-fill: #8AAACF; -fx-font-size: 16px; -fx-font-family: 'Georgia'; -fx-letter-spacing: 2;"/>

        <Region prefHeight="24"/>

        <Separator style="-fx-background-color: rgba(255,255,255,0.08);" maxWidth="200"/>

        <Region prefHeight="12"/>

        <Label text="Compassionate care for a healthier mind."
               style="-fx-text-fill: #5A7A9A; -fx-font-size: 13px; -fx-font-style: italic; -fx-font-family: 'Georgia';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>

        <Label text="Where healing begins with understanding."
               style="-fx-text-fill: #4A6B8A; -fx-font-size: 11px; -fx-font-family: 'Georgia';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>
    </VBox>

    <!-- ═══════════ RIGHT LOGIN PANEL ═══════════ -->
    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-min-width: 520;">
        <padding>
            <Insets top="40" right="80" bottom="40" left="80"/>
        </padding>

        <!-- Login Card -->
        <VBox alignment="CENTER" spacing="6" maxWidth="420"
              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 30, 0, 0, 10);">
            <padding>
                <Insets top="48" right="44" bottom="40" left="44"/>
            </padding>

            <!-- Header -->
            <Label text="Welcome Back"
                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 26px; -fx-font-weight: bold;"/>
            <Label text="Sign in to your account"
                   style="-fx-text-fill: #6A8AAA; -fx-font-size: 13px;"/>

            <Region prefHeight="28"/>

            <!-- Username -->
            <Label text="USERNAME" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1;"
                   alignment="CENTER_LEFT" maxWidth="Infinity"/>
            <TextField fx:id="txtUsername" promptText="Enter your username"
                       style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #5A7A9A; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;"/>

            <Region prefHeight="8"/>

            <!-- Password -->
            <Label text="PASSWORD" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1;"
                   alignment="CENTER_LEFT" maxWidth="Infinity"/>
            <HBox fx:id="passwordContainer" spacing="6" alignment="CENTER">
                <PasswordField fx:id="txtPassword" promptText="Enter your password" HBox.hgrow="ALWAYS"
                               style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #5A7A9A; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;"/>
                <TextField fx:id="txtPasswordVisible" promptText="Enter your password" HBox.hgrow="ALWAYS" visible="false" managed="false"
                           style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #5A7A9A; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;"/>
                <Button fx:id="btnTogglePassword" text="👁" onAction="#handleTogglePassword" mnemonicParsing="false"
                        style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #8AAACF; -fx-font-size: 16px; -fx-padding: 8 12; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-cursor: hand;"/>
            </HBox>

            <!-- Forgot Password link -->
            <HBox alignment="CENTER_RIGHT">
                <Hyperlink text="Forgot Password?" onAction="#handleForgotPassword"
                           style="-fx-text-fill: #5BB8D4; -fx-font-size: 11px; -fx-border-color: transparent;"/>
            </HBox>

            <Region prefHeight="4"/>

            <!-- Error Label -->
            <Label fx:id="lblError" text="" style="-fx-text-fill: #E07070; -fx-font-size: 11px;" wrapText="true" maxWidth="Infinity" alignment="CENTER"/>

            <!-- Login Button -->
            <Button text="Sign In" onAction="#handleLogin" maxWidth="Infinity" mnemonicParsing="false"
                    style="-fx-background-color: linear-gradient(to right, #2E6DA4, #1A4F7A); -fx-text-fill: #FFFFFF; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 14; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(46,109,164,0.4), 10, 0, 0, 4);"/>

            <Region prefHeight="16"/>

            <Separator style="-fx-background-color: rgba(255,255,255,0.06);"/>

            <Region prefHeight="8"/>

            <!-- Create Account -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Don't have an account?" style="-fx-text-fill: #5A7A9A; -fx-font-size: 12px;"/>
                <Hyperlink text="Create Account" onAction="#handleCreateAccount"
                           style="-fx-text-fill: #5BB8D4; -fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: transparent;"/>
            </HBox>

            <Region prefHeight="8"/>

            <!-- Footer -->
            <Label text="© 2025 Serenity Therapy Center" style="-fx-text-fill: #3A5A7A; -fx-font-size: 9px;"/>
        </VBox>
    </VBox>
</HBox>
