<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.LoginController"
      stylesheets="@calm-clarity.css"
      style="-fx-background-color: linear-gradient(to bottom right, #FAF8F5, #F0ECE6);"
      prefWidth="1280" prefHeight="800">

    <!-- ═══════════ LEFT BRANDING PANEL ═══════════ -->
    <VBox alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS"
          style="-fx-background-color: rgba(139,175,158,0.08); -fx-min-width: 520;">
        <padding>
            <Insets top="60" right="60" bottom="60" left="60"/>
        </padding>

        <!-- Decorative circles -->
        <StackPane maxWidth="120" maxHeight="120">
            <Circle radius="60" style="-fx-fill: rgba(107,157,194,0.1); -fx-stroke: rgba(107,157,194,0.2); -fx-stroke-width: 2;"/>
            <Circle radius="40" style="-fx-fill: rgba(139,175,158,0.15); -fx-stroke: rgba(139,175,158,0.25); -fx-stroke-width: 1;"/>
            <Label text="🌿" style="-fx-font-size: 48px;"/>
        </StackPane>

        <Region prefHeight="16"/>

        <Label text="Serenity"
               style="-fx-text-fill: #2D3436; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
        <Label text="Mental Health Therapy Center"
               style="-fx-text-fill: #636E72; -fx-font-size: 16px; -fx-font-family: 'Segoe UI';"/>

        <Region prefHeight="24"/>

        <Separator style="-fx-background-color: #E5DFD8;" maxWidth="200"/>

        <Region prefHeight="12"/>

        <Label text="Compassionate care for a healthier mind."
               style="-fx-text-fill: #8BAF9E; -fx-font-size: 13px; -fx-font-style: italic; -fx-font-family: 'Segoe UI';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>

        <Label text="Where healing begins with understanding."
               style="-fx-text-fill: #95A5A6; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>
    </VBox>

    <!-- ═══════════ RIGHT LOGIN PANEL ═══════════ -->
    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-min-width: 520;">
        <padding>
            <Insets top="40" right="80" bottom="40" left="80"/>
        </padding>

        <!-- Login Card -->
        <VBox alignment="CENTER" spacing="6" maxWidth="420"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5DFD8; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.08), 20, 0, 0, 6);">
            <padding>
                <Insets top="48" right="44" bottom="40" left="44"/>
            </padding>

            <!-- Header -->
            <Label text="Welcome Back"
                   style="-fx-text-fill: #2D3436; -fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
            <Label text="Sign in to your account"
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 13px; -fx-font-family: 'Segoe UI';"/>

            <Region prefHeight="28"/>

            <!-- Username -->
            <Label text="USERNAME" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"
                   alignment="CENTER_LEFT" maxWidth="Infinity"/>
            <TextField fx:id="txtUsername" promptText="Enter your username"/>

            <Region prefHeight="8"/>

            <!-- Password -->
            <Label text="PASSWORD" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"
                   alignment="CENTER_LEFT" maxWidth="Infinity"/>
            <HBox fx:id="passwordContainer" spacing="6" alignment="CENTER">
                <PasswordField fx:id="txtPassword" promptText="Enter your password" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtPasswordVisible" promptText="Enter your password" HBox.hgrow="ALWAYS" visible="false" managed="false"/>
                <Button fx:id="btnTogglePassword" text="👁" onAction="#handleTogglePassword" mnemonicParsing="false"
                        style="-fx-background-color: #F2F7FB; -fx-text-fill: #6B9DC2; -fx-font-size: 16px; -fx-padding: 8 12; -fx-background-radius: 12; -fx-border-color: #E5DFD8; -fx-border-radius: 12; -fx-cursor: hand;"/>
            </HBox>

            <!-- Forgot Password link -->
            <HBox alignment="CENTER_RIGHT">
                <Hyperlink text="Forgot Password?" onAction="#handleForgotPassword"
                           style="-fx-text-fill: #4A7FA5; -fx-font-size: 11px; -fx-border-color: transparent;"/>
            </HBox>

            <Region prefHeight="4"/>

            <!-- Error Label -->
            <Label fx:id="lblError" text="" style="-fx-text-fill: #C47171; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';" wrapText="true" maxWidth="Infinity" alignment="CENTER"/>

            <!-- Login Button -->
            <Button text="Sign In" onAction="#handleLogin" maxWidth="Infinity" mnemonicParsing="false"
                    styleClass="btn-primary"/>

            <Region prefHeight="16"/>

            <Separator/>

            <Region prefHeight="8"/>

            <!-- Create Account -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Don't have an account?" style="-fx-text-fill: #95A5A6; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';"/>
                <Hyperlink text="Create Account" onAction="#handleCreateAccount"
                           style="-fx-text-fill: #4A7FA5; -fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: transparent;"/>
            </HBox>

            <Region prefHeight="8"/>

            <!-- Footer -->
            <Label text="© 2025 Serenity Therapy Center" style="-fx-text-fill: #B8B0A6; -fx-font-size: 9px; -fx-font-family: 'Segoe UI';"/>
        </VBox>
    </VBox>
</HBox>
