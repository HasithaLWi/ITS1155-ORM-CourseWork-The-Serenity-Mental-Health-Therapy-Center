<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="24" style="-fx-padding: 28;">
        <!-- Stats Cards -->
        <HBox spacing="16">
            <VBox spacing="8" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-padding: 20; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="🧑‍🤝‍🧑" style="-fx-font-size: 22px; -fx-background-color: #E8F1F8; -fx-padding: 10; -fx-background-radius: 12;"/>
                    <VBox>
                        <Label text="Total Patients" style="-fx-text-fill: #95A5A6; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalPatients" text="0" style="-fx-text-fill: #2D3436; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox spacing="8" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-padding: 20; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="📅" style="-fx-font-size: 22px; -fx-background-color: #E8F2ED; -fx-padding: 10; -fx-background-radius: 12;"/>
                    <VBox>
                        <Label text="Today's Sessions" style="-fx-text-fill: #95A5A6; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblTodaySessions" text="0" style="-fx-text-fill: #2D3436; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!-- Today's Sessions Table -->
        <VBox spacing="0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 20 16 20;">
                <Label text="📅  Today's Sessions" style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            </HBox>
            <Separator/>
            <TableView fx:id="tblTodaySessions" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colTodayTime" text="Time" prefWidth="100"/>
                    <TableColumn fx:id="colTodayPatient" text="Patient" prefWidth="180"/>
                    <TableColumn fx:id="colTodayTherapist" text="Therapist" prefWidth="180"/>
                    <TableColumn fx:id="colTodayProgram" text="Program" prefWidth="200"/>
                    <TableColumn fx:id="colTodayStatus" text="Status" prefWidth="120"/>
                </columns>
                <placeholder><Label text="No sessions scheduled for today." style="-fx-text-fill: #95A5A6; -fx-font-size: 13px;"/></placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
