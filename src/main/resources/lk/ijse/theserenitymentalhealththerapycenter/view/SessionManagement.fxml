<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.SessionManagementController">
    <VBox spacing="20" style="-fx-padding: 28;">
        <!-- Scheduling Form -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <Label style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;" text="📅  Schedule New Session" />
            <Separator />
         <HBox layoutX="35.0" layoutY="83.0" spacing="16">
            <children>
               <VBox prefWidth="200.0" spacing="4">
                  <children>
                     <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="SESSION ID" />
                     <ComboBox fx:id="cmbSessionId" maxWidth="Infinity" promptText="Select Session" styleClass="combo-autocomplete" />
                  </children>
               </VBox>
            </children>
         </HBox>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="PATIENT" />
                    <ComboBox fx:id="cmbSessionPatient" maxWidth="Infinity" promptText="Select patient" styleClass="combo-autocomplete" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="THERAPIST" />
                    <ComboBox fx:id="cmbSessionTherapist" maxWidth="Infinity" promptText="Select therapist" styleClass="combo-autocomplete" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="PROGRAM" />
                    <ComboBox fx:id="cmbSessionProgram" maxWidth="Infinity" promptText="Select program" styleClass="combo-autocomplete" />
                </VBox>
            </HBox>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="DATE" />
                    <DatePicker fx:id="dpSessionDate" maxWidth="Infinity" promptText="Select date" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="TIME" />
                    <ComboBox fx:id="cmbSessionTime" maxWidth="Infinity" promptText="Select time" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="STATUS" />
                    <ComboBox fx:id="cmbSessionStatus" maxWidth="Infinity" promptText="Status" />
                </VBox>
            </HBox>
            <VBox spacing="4">
                <Label style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;" text="NOTES" />
                <TextArea fx:id="txtSessionNotes" prefRowCount="2" promptText="Session notes..." style="-fx-background-color: #FFFFFF; -fx-border-color: #E5DFD8; -fx-border-radius: 12; -fx-background-radius: 12; -fx-font-size: 13px; -fx-padding: 8;" wrapText="true" />
            </VBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region HBox.hgrow="ALWAYS" />
            <HBox fx:id="hboxSessionActions" spacing="10.0">
               <children>
                       <Button maxHeight="1.7976931348623157E308" onAction="#handleCompleteSession" style="-fx-background-color: #7AB88F; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 10; -fx-cursor: hand;" text="✅  Complete Session" HBox.hgrow="ALWAYS" />
                       <Button maxHeight="1.7976931348623157E308" onAction="#handleCancelSession" style="-fx-background-color: #C47171; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 10; -fx-cursor: hand;" text="↩  Cancel/Reschedule" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            <Button fx:id="btnSessionPay" layoutX="650.0" layoutY="14.0" styleClass="btn-secondary" text="💵 Pay" />
                <Button onAction="#handleUpdateSession" styleClass="btn-secondary" text="✏️  Update" />
                <Button onAction="#handleClearSession" styleClass="btn-secondary" text="🔄  Clear" />
            </HBox>
        </VBox>
      <VBox fx:id="vboxPatientSessions" layoutX="38.0" layoutY="389.0" spacing="0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">
         <children>
               <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 20 16 20;">
                   <Label style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;" text="Patient Sessions" />
               </HBox>
               <Separator />
               <TableView fx:id="tblPatientSessions" prefHeight="200" VBox.vgrow="ALWAYS">
                   <columns>
                       <TableColumn fx:id="colPatSessionId" prefWidth="50" text="ID" />
                       <TableColumn fx:id="colPatSequenceNumber" prefWidth="40" text="Seq" />
                       <TableColumn fx:id="colPatSessionDate" prefWidth="100" text="Date" />
                       <TableColumn fx:id="colPatSessionTime" prefWidth="70" text="Time" />
                       <TableColumn fx:id="colPatSessionTherapist" prefWidth="130" text="Therapist" />
                       <TableColumn fx:id="colPatSessionProgram" prefWidth="140" text="Program" />
                       <TableColumn fx:id="colPatSessionStatus" prefWidth="100" text="Status" />
                       <TableColumn fx:id="colPatPaymentStatus" prefWidth="80" text="Payment" />
                   </columns>
                   <placeholder>
                  <Label style="-fx-text-fill: #95A5A6; -fx-font-size: 13px;" text="No sessions found for this patient." />
               </placeholder>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               </TableView>
         </children>
      </VBox>

        <!-- Sessions Table -->
        <VBox spacing="0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 20 20 16 20;">
                <Label style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;" text="All Sessions" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtAllSessionSearch" prefWidth="220" promptText="🔍  Search..." style="-fx-background-color: #F5F0EB; -fx-border-color: transparent; -fx-background-radius: 10; -fx-padding: 8 12; -fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
            </HBox>
            <Separator />
            <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 20 10 20;">
                <Label minWidth="-Infinity" style="-fx-text-fill: #8BAF9E; -fx-font-size: 12px; -fx-font-weight: bold;" text="Filter by:" />
                <DatePicker fx:id="dpFilterDate" minWidth="100.0" prefWidth="120" promptText="Date" style="-fx-font-size: 12px;" />
                <ComboBox fx:id="cmbFilterTime" minWidth="100.0" prefWidth="100" promptText="Time" style="-fx-font-size: 12px;" />
                <ComboBox fx:id="cmbFilterTherapist" maxWidth="300.0" minWidth="100.0" promptText="Therapist" style="-fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="cmbFilterProgram" maxWidth="1.7976931348623157E308" minWidth="100.0" promptText="Program" style="-fx-font-size: 12px;" HBox.hgrow="ALWAYS" />
                <Button minWidth="-Infinity" onAction="#handleClearFilters" style="-fx-font-size: 11px; -fx-padding: 4 8;" styleClass="btn-secondary" text="❌ Clear Filters" />
            </HBox>
            <Separator />
            <TableView fx:id="tblSessions" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colSessionId" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colSequenceNumber" prefWidth="40" text="Seq" />
                    <TableColumn fx:id="colSessionDate" prefWidth="100" text="Date" />
                    <TableColumn fx:id="colSessionTime" prefWidth="70" text="Time" />
                    <TableColumn fx:id="colSessionPatient" prefWidth="130" text="Patient" />
                    <TableColumn fx:id="colSessionTherapist" prefWidth="130" text="Therapist" />
                    <TableColumn fx:id="colSessionProgram" prefWidth="140" text="Program" />
                    <TableColumn fx:id="colSessionStatus" prefWidth="100" text="Status" />
                    <TableColumn fx:id="colPaymentStatus" prefWidth="80" text="Payment" />
                </columns>
                <placeholder><Label style="-fx-text-fill: #95A5A6; -fx-font-size: 13px;" text="No sessions found." /></placeholder>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
