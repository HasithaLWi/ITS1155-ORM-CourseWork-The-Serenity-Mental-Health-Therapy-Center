<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.RegistrationController"
      stylesheets="@calm-clarity.css"
      style="-fx-background-color: linear-gradient(to bottom right, #FAF8F5, #F0ECE6);"
      prefWidth="1280" prefHeight="800">

    <!-- ═══════════ LEFT BRANDING PANEL ═══════════ -->
    <VBox alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS"
          style="-fx-background-color: rgba(139,175,158,0.08); -fx-min-width: 480;">
        <padding>
            <Insets top="60" right="60" bottom="60" left="60"/>
        </padding>

        <StackPane maxWidth="120" maxHeight="120">
            <Circle radius="60" style="-fx-fill: rgba(107,157,194,0.1); -fx-stroke: rgba(107,157,194,0.2); -fx-stroke-width: 2;"/>
            <Circle radius="40" style="-fx-fill: rgba(139,175,158,0.15); -fx-stroke: rgba(139,175,158,0.25); -fx-stroke-width: 1;"/>
            <Label text="🌿" style="-fx-font-size: 48px;"/>
        </StackPane>

        <Region prefHeight="16"/>

        <Label text="Serenity"
               style="-fx-text-fill: #2D3436; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
        <Label text="Mental Health Therapy Center"
               style="-fx-text-fill: #636E72; -fx-font-size: 16px; -fx-font-family: 'Segoe UI';"/>

        <Region prefHeight="24"/>

        <Separator style="-fx-background-color: #E5DFD8;" maxWidth="200"/>

        <Region prefHeight="12"/>

        <Label text="Join our team and make a difference."
               style="-fx-text-fill: #8BAF9E; -fx-font-size: 13px; -fx-font-style: italic; -fx-font-family: 'Segoe UI';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>

        <Label text="Create your account to get started."
               style="-fx-text-fill: #95A5A6; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>
    </VBox>

    <!-- ═══════════ RIGHT REGISTRATION PANEL ═══════════ -->
    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-min-width: 560;">
        <padding>
            <Insets top="20" right="60" bottom="20" left="60"/>
        </padding>

        <!-- Registration Card -->
        <VBox alignment="CENTER" spacing="4" maxWidth="460"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E5DFD8; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.08), 20, 0, 0, 6);">
            <padding>
                <Insets top="32" right="40" bottom="28" left="40"/>
            </padding>

            <!-- Header -->
            <Label text="Create Account"
                   style="-fx-text-fill: #2D3436; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
            <Label text="Fill in your details to register"
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';"/>

            <Region prefHeight="16"/>

            <!-- Scrollable form area -->
            <ScrollPane fitToWidth="true" maxHeight="520" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
                <VBox spacing="3">
                    <padding>
                        <Insets top="4" right="8" bottom="4" left="4"/>
                    </padding>

                    <!-- Full Name -->
                    <Label text="FULL NAME" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtFullName" promptText="Enter your full name"/>
                    <Label fx:id="lblFullNameError" text="" style="-fx-font-size: 10px;"/>

                    <!-- Email -->
                    <Label text="EMAIL" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEmail" promptText="Enter your email address"/>
                    <Label fx:id="lblEmailError" text="" style="-fx-font-size: 10px;"/>

                    <!-- Username -->
                    <Label text="USERNAME" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtUsername" promptText="Choose a username"/>
                    <Label fx:id="lblUsernameError" text="" style="-fx-font-size: 10px;"/>

                    <!-- Password row -->
                    <HBox spacing="12">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="PASSWORD" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="txtPassword" promptText="Min 6 characters"/>
                            <Label fx:id="lblPasswordError" text="" style="-fx-font-size: 10px;"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="CONFIRM PASSWORD" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="txtConfirmPassword" promptText="Repeat password"/>
                            <Label fx:id="lblConfirmPasswordError" text="" style="-fx-font-size: 10px;"/>
                        </VBox>
                    </HBox>

                    <Region prefHeight="4"/>
                    <Separator/>
                    <Region prefHeight="2"/>

                    <Label text="SECURITY QUESTION" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbSecurityQuestion" promptText="Select a security question" maxWidth="Infinity"/>
                    <Label fx:id="lblSecurityQuestionError" text="" style="-fx-font-size: 10px;"/>

                    <Label text="SECURITY ANSWER" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtSecurityAnswer" promptText="Your answer (case-insensitive)"/>
                    <Label fx:id="lblSecurityAnswerError" text="" style="-fx-font-size: 10px;"/>
                </VBox>
            </ScrollPane>

            <Region prefHeight="6"/>

            <!-- Message -->
            <Label fx:id="lblMessage" text="" wrapText="true" maxWidth="Infinity" alignment="CENTER"
                   style="-fx-font-size: 12px; -fx-font-family: 'Segoe UI';"/>

            <!-- Register Button -->
            <Button text="Create Account" onAction="#handleRegister" maxWidth="Infinity" mnemonicParsing="false"
                    styleClass="btn-primary"/>

            <Region prefHeight="10"/>

            <!-- Back to Login -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Already have an account?" style="-fx-text-fill: #95A5A6; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';"/>
                <Hyperlink text="Sign In" onAction="#handleBackToLogin"
                           style="-fx-text-fill: #4A7FA5; -fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
