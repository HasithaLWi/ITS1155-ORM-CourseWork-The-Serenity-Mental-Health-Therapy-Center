<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.AdminDashboardController"
            prefWidth="1280" prefHeight="800"
            style="-fx-background-color: #F0F4F8;">

    <!-- ===== LEFT SIDEBAR ===== -->
    <left>
        <VBox prefWidth="240" spacing="0"
              style="-fx-background-color: #1A2B4A; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 2, 0);">

            <!-- Logo / Brand -->
            <VBox alignment="CENTER" spacing="6" style="-fx-padding: 28 20 24 20; -fx-background-color: #142038;">
                <Label text="🌿" style="-fx-font-size: 32px;"/>
                <Label text="Serenity" style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                <Label text="Mental Health Therapy Center" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-text-alignment: center; -fx-wrap-text: true; -fx-font-family: 'Georgia';"/>
                <Separator style="-fx-background-color: #2E4A72;" prefWidth="180" prefHeight="1"/>
                <Label text="ADMIN PORTAL" style="-fx-text-fill: #5B9BD5; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
            </VBox>

            <!-- Navigation Menu -->
            <VBox spacing="2" style="-fx-padding: 16 12 16 12;" VBox.vgrow="ALWAYS">

                <!-- Dashboard -->
                <Button fx:id="btnDashboard" text="  📊   Dashboard" maxWidth="Infinity"
                        onAction="#showDashboard"
                        style="-fx-background-color: #2E6DA4; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <Label text="MANAGEMENT" style="-fx-text-fill: #4A6B8A; -fx-font-size: 9px; -fx-font-weight: bold; -fx-letter-spacing: 1.5px; -fx-padding: 14 16 4 16;"/>

                <!-- Therapist Management -->
                <Button fx:id="btnTherapists" text="  👨‍⚕️   Therapist Management" maxWidth="Infinity"
                        onAction="#showTherapistManagement"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4E0; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <!-- Therapy Programs -->
                <Button fx:id="btnPrograms" text="  📋   Therapy Programs" maxWidth="Infinity"
                        onAction="#showProgramManagement"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4E0; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <Label text="OPERATIONS" style="-fx-text-fill: #4A6B8A; -fx-font-size: 9px; -fx-font-weight: bold; -fx-letter-spacing: 1.5px; -fx-padding: 14 16 4 16;"/>

                <!-- Patient Overview -->
                <Button fx:id="btnPatients" text="  🧑‍🤝‍🧑   Patient Overview" maxWidth="Infinity"
                        onAction="#showPatientOverview"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4E0; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <!-- Session Scheduling -->
                <Button fx:id="btnScheduling" text="  📅   Session Scheduling" maxWidth="Infinity"
                        onAction="#showScheduling"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4E0; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <Label text="FINANCE &amp; REPORTS" style="-fx-text-fill: #4A6B8A; -fx-font-size: 9px; -fx-font-weight: bold; -fx-letter-spacing: 1.5px; -fx-padding: 14 16 4 16;"/>

                <!-- Payments -->
                <Button fx:id="btnPayments" text="  💳   Payments &amp; Invoices" maxWidth="Infinity"
                        onAction="#showPayments"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4E0; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <!-- Reports -->
                <Button fx:id="btnReports" text="  📈   Reports &amp; Analytics" maxWidth="Infinity"
                        onAction="#showReports"
                        style="-fx-background-color: transparent; -fx-text-fill: #A8C4E0; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Separator style="-fx-background-color: #2E4A72;"/>

                <!-- Logout -->
                <Button text="  🚪   Logout" maxWidth="Infinity"
                        onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: #E07070; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>

            <!-- Admin Profile Bottom -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 16 16 20 16; -fx-background-color: #142038;">
                <Label text="AD" style="-fx-background-color: #2E6DA4; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-min-width: 36; -fx-min-height: 36; -fx-alignment: CENTER; -fx-background-radius: 18;"/>
                <VBox spacing="2">
                    <Label fx:id="lblAdminName" text="Admin User"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Label text="Administrator"
                           style="-fx-text-fill: #5B9BD5; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <!-- ===== MAIN CONTENT AREA ===== -->
    <center>
        <VBox spacing="0">

            <!-- Top Header Bar -->
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color: #FFFFFF; -fx-padding: 14 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">
                <VBox>
                    <Label fx:id="lblPageTitle" text="Dashboard Overview"
                           style="-fx-text-fill: #1A2B4A; -fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                    <Label fx:id="lblPageSubtitle" text="Welcome back, Administrator"
                           style="-fx-text-fill: #7A92A8; -fx-font-size: 12px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCurrentDate" text="Sunday, April 27, 2025"
                       style="-fx-text-fill: #7A92A8; -fx-font-size: 12px;"/>
                <Button text="🔔" style="-fx-background-color: #F0F4F8; -fx-font-size: 16px; -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>

            <!-- Scrollable Content -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="24" style="-fx-padding: 28 28 28 28;">

                    <!-- ===== STATS CARDS ROW ===== -->
                    <HBox spacing="16">

                        <!-- Total Patients -->
                        <VBox spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #FFFFFF; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="🧑‍🤝‍🧑" style="-fx-font-size: 22px; -fx-background-color: #EBF4FF; -fx-padding: 10; -fx-background-radius: 10;"/>
                                <VBox>
                                    <Label text="Total Patients" style="-fx-text-fill: #7A92A8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;"/>
                                    <Label fx:id="lblTotalPatients" text="0"
                                           style="-fx-text-fill: #1A2B4A; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Active Therapists -->
                        <VBox spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #FFFFFF; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="👨‍⚕️" style="-fx-font-size: 22px; -fx-background-color: #F0FFF8; -fx-padding: 10; -fx-background-radius: 10;"/>
                                <VBox>
                                    <Label text="Active Therapists" style="-fx-text-fill: #7A92A8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;"/>
                                    <Label fx:id="lblTotalTherapists" text="0"
                                           style="-fx-text-fill: #1A2B4A; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Active Programs -->
                        <VBox spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #FFFFFF; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="📋" style="-fx-font-size: 22px; -fx-background-color: #FFF8EB; -fx-padding: 10; -fx-background-radius: 10;"/>
                                <VBox>
                                    <Label text="Therapy Programs" style="-fx-text-fill: #7A92A8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;"/>
                                    <Label fx:id="lblTotalPrograms" text="0"
                                           style="-fx-text-fill: #1A2B4A; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Monthly Revenue -->
                        <VBox spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #FFFFFF; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="💰" style="-fx-font-size: 22px; -fx-background-color: #FFF0F5; -fx-padding: 10; -fx-background-radius: 10;"/>
                                <VBox>
                                    <Label text="Monthly Revenue" style="-fx-text-fill: #7A92A8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;"/>
                                    <Label fx:id="lblMonthlyRevenue" text="LKR 0"
                                           style="-fx-text-fill: #1A2B4A; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- ===== THERAPIST MANAGEMENT TABLE ===== -->
                    <VBox spacing="0"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 20 16 20;">
                            <Label text="👨‍⚕️  Therapist Management"
                                   style="-fx-text-fill: #1A2B4A; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="txtSearchTherapist" promptText="🔍  Search therapist..."
                                       prefWidth="200"
                                       style="-fx-background-color: #F0F4F8; -fx-border-color: transparent; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 12px;"/>
                            <Button text="+ Add Therapist" onAction="#showAddTherapistDialog"
                                    style="-fx-background-color: #1A2B4A; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>
                        <Separator/>
                        <TableView fx:id="therapistTable" prefHeight="220"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="colTherapistId" text="ID" prefWidth="80" style="-fx-font-weight: bold;"/>
                                <TableColumn fx:id="colTherapistName" text="Full Name" prefWidth="200"/>
                                <TableColumn fx:id="colTherapistSpecialty" text="Specialty" prefWidth="180"/>
                                <TableColumn fx:id="colTherapistStatus" text="Status" prefWidth="100"/>
                                <TableColumn fx:id="colTherapistActions" text="Actions" prefWidth="150"/>
                            </columns>
                            <placeholder>
                                <Label text="No therapists found." style="-fx-text-fill: #A0B0C0; -fx-font-size: 13px;"/>
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- ===== THERAPY PROGRAMS TABLE ===== -->
                    <VBox spacing="0"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 20 16 20;">
                            <Label text="📋  Therapy Programs"
                                   style="-fx-text-fill: #1A2B4A; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="+ Add Program" onAction="#showAddProgramDialog"
                                    style="-fx-background-color: #1A2B4A; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>
                        <Separator/>
                        <TableView fx:id="programTable" prefHeight="220"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="colProgramId" text="Program ID" prefWidth="100"/>
                                <TableColumn fx:id="colProgramName" text="Program Name" prefWidth="220"/>
                                <TableColumn fx:id="colDuration" text="Duration" prefWidth="110"/>
                                <TableColumn fx:id="colFee" text="Fee (LKR)" prefWidth="120"/>
                                <TableColumn fx:id="colProgramActions" text="Actions" prefWidth="130"/>
                            </columns>
                            <placeholder>
                                <Label text="No programs found." style="-fx-text-fill: #A0B0C0; -fx-font-size: 13px;"/>
                            </placeholder>
                        </TableView>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
