<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.PatientListController"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="20" style="-fx-padding: 28;">
        <!-- Edit Patient Details Form -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <Label text="✏️  Edit Patient" style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Separator/>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="FULL NAME" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEditName" promptText="Patient name"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="EMAIL" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEditEmail" promptText="Email"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="PHONE" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEditPhone" promptText="Phone"/>
                </VBox>
            </HBox>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="ADDRESS" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtEditAddress" promptText="Address"/>
                </VBox>
            </HBox>
            <VBox spacing="4">
                <Label text="INTERVIEW NOTE" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                <TextArea fx:id="txtEditInterviewNote" promptText="Interview notes..." prefRowCount="3"
                          style="-fx-background-color: #FFFFFF; -fx-border-color: #E5DFD8; -fx-border-radius: 12; -fx-background-radius: 12; -fx-font-size: 13px; -fx-padding: 8;" wrapText="true"/>
            </VBox>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="✏️  Update" onAction="#handleUpdatePatient" styleClass="btn-primary" style="-fx-padding: 10 24;"/>
                <Button text="🔄  Clear" onAction="#handleClearEditForm" styleClass="btn-secondary"/>
            </HBox>
        </VBox>

        <!-- Enrolled Programs Section (shown when patient is selected) -->
        <VBox fx:id="vboxEnrolledPrograms" spacing="0" visible="false" managed="false"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 20 16 20;">
                <Label text="📋  Enrolled Programs" style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            </HBox>
            <Separator/>
            <TableView fx:id="tblEnrolledPrograms" prefHeight="150">
                <columns>
                    <TableColumn fx:id="colEnrProgramName" text="Program" prefWidth="200"/>
                    <TableColumn fx:id="colEnrTotalSessions" text="Total Sessions" prefWidth="100"/>
                    <TableColumn fx:id="colEnrUpfrontPaid" text="Upfront Paid" prefWidth="100"/>
                    <TableColumn fx:id="colEnrUsed" text="Used" prefWidth="70"/>
                    <TableColumn fx:id="colEnrRemaining" text="Credit Left" prefWidth="90"/>
                    <TableColumn fx:id="colEnrCompleted" text="Completed" prefWidth="90"/>
                    <TableColumn fx:id="colEnrStatus" text="Status" prefWidth="100"/>
                </columns>
                <placeholder><Label text="No programs enrolled." style="-fx-text-fill: #95A5A6; -fx-font-size: 13px;"/></placeholder>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <!-- Enroll in New Program -->
            <Separator/>
            <VBox spacing="8" style="-fx-padding: 16 20;">
                <Label text="➕  Enroll in New Program" style="-fx-text-fill: #2D3436; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="PROGRAM" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="cmbNewProgram" promptText="Select program" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="SESSIONS TO PAY" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="cmbNewProgramSessions" promptText="0" prefWidth="100"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="COST" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblNewProgramCost" text="0 LKR" style="-fx-font-size: 13px; -fx-text-fill: #2D3436; -fx-padding: 8 0;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="METHOD" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="cmbNewProgramPayMethod" promptText="Method" prefWidth="120"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="" style="-fx-font-size: 10px;"/>
                        <Button text="✅ Enroll &amp; Pay" onAction="#handleEnrollNewProgram"
                                style="-fx-background-color: #4A7FA5; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <!-- Patient Table -->
        <VBox spacing="0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 20 16 20;">
                <Label text="🧑‍🤝‍🧑  Patient Records" style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtSearchPatient" promptText="🔍  Search..." prefWidth="220" style="-fx-background-color: #F5F0EB; -fx-border-color: transparent; -fx-background-radius: 10; -fx-padding: 8 12; -fx-font-size: 12px;"/>
                <Button text="🗑  Delete" onAction="#handleDeletePatient" style="-fx-background-color: #C47171; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 10; -fx-cursor: hand;"/>
            </HBox>
            <Separator/>
            <TableView fx:id="tblPatients" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colPatientId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colPatientName" text="Name" prefWidth="180"/>
                    <TableColumn fx:id="colPatientEmail" text="Email" prefWidth="180"/>
                    <TableColumn fx:id="colPatientPhone" text="Phone" prefWidth="130"/>
                    <TableColumn fx:id="colPatientAddress" text="Address" prefWidth="180"/>
                    <TableColumn fx:id="colPatientDate" text="Registered" prefWidth="110"/>
                </columns>
                <placeholder><Label text="No patients found." style="-fx-text-fill: #95A5A6; -fx-font-size: 13px;"/></placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
