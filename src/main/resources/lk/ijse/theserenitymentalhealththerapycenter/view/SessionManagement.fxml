<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.SessionManagementController"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="20" style="-fx-padding: 28;">
        <!-- Scheduling Form -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <Label text="📅  Schedule New Session" style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Separator/>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="PATIENT" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbSessionPatient" promptText="Select patient" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="THERAPIST" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbSessionTherapist" promptText="Select therapist" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="PROGRAM" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbSessionProgram" promptText="Select program" maxWidth="Infinity"/>
                </VBox>
            </HBox>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="DATE" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dpSessionDate" promptText="Select date" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="TIME" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbSessionTime" promptText="Select time" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="STATUS" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbSessionStatus" promptText="Status" maxWidth="Infinity"/>
                </VBox>
            </HBox>
            <VBox spacing="4">
                <Label text="NOTES" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                <TextArea fx:id="txtSessionNotes" promptText="Session notes..." prefRowCount="2" wrapText="true"
                          style="-fx-background-color: #FFFFFF; -fx-border-color: #E5DFD8; -fx-border-radius: 12; -fx-background-radius: 12; -fx-font-size: 13px; -fx-padding: 8;"/>
            </VBox>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="💾  Schedule" onAction="#handleScheduleSession" styleClass="btn-primary" style="-fx-padding: 10 24;"/>
                <Button text="✏️  Update" onAction="#handleUpdateSession" styleClass="btn-secondary"/>
                <Button text="🔄  Clear" onAction="#handleClearSession" styleClass="btn-secondary"/>
            </HBox>
        </VBox>

        <!-- Sessions Table -->
        <VBox spacing="0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 20 16 20;">
                <Label text="All Sessions" style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🗑  Delete" onAction="#handleDeleteSession" style="-fx-background-color: #C47171; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 10; -fx-cursor: hand;"/>
            </HBox>
            <Separator/>
            <TableView fx:id="tblSessions" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colSessionId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colSessionDate" text="Date" prefWidth="110"/>
                    <TableColumn fx:id="colSessionTime" text="Time" prefWidth="80"/>
                    <TableColumn fx:id="colSessionPatient" text="Patient" prefWidth="150"/>
                    <TableColumn fx:id="colSessionTherapist" text="Therapist" prefWidth="150"/>
                    <TableColumn fx:id="colSessionProgram" text="Program" prefWidth="160"/>
                    <TableColumn fx:id="colSessionStatus" text="Status" prefWidth="110"/>
                </columns>
                <placeholder><Label text="No sessions found." style="-fx-text-fill: #95A5A6; -fx-font-size: 13px;"/></placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
