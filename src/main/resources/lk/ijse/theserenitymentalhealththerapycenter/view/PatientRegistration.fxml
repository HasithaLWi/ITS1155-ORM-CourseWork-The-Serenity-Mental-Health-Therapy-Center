<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.PatientRegistrationController"
            fitToWidth="true" style="-fx-background-color: transparent;">
    <VBox spacing="20" style="-fx-padding: 28;">
        <!-- Registration Form -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-background-radius: 16; -fx-border-color: #E5DFD8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(45,52,54,0.05), 8, 0, 0, 2);">
            <Label text="➕  Register New Patient" style="-fx-text-fill: #2D3436; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Separator/>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="FULL NAME *" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtPatientName" promptText="Enter patient name"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="EMAIL" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtPatientEmail" promptText="Email address"/>
                </VBox>
            </HBox>
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="PHONE" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtPatientPhone" promptText="Phone number"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="ADDRESS" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtPatientAddress" promptText="Address"/>
                </VBox>
            </HBox>
            <VBox spacing="4">
                <Label text="THERAPY PROGRAM" style="-fx-text-fill: #8BAF9E; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbPatientProgram" promptText="Select therapy program to enroll" maxWidth="Infinity"/>
            </VBox>
            <Label fx:id="lblRegMessage" text="" style="-fx-font-size: 12px;" wrapText="true"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="💾  Register Patient" onAction="#handleRegisterPatient" styleClass="btn-primary" style="-fx-padding: 10 24;"/>
                <Button text="🔄  Clear" onAction="#handleClearPatientForm" styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
