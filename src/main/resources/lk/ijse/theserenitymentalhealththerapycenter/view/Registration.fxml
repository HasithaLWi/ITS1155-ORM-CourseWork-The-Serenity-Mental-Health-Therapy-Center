<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="lk.ijse.theserenitymentalhealththerapycenter.controller.RegistrationController"
      style="-fx-background-color: linear-gradient(to bottom right, #0A1628, #1A2B4A);"
      prefWidth="1280" prefHeight="800">

    <!-- ═══════════ LEFT BRANDING PANEL ═══════════ -->
    <VBox alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS"
          style="-fx-background-color: rgba(255,255,255,0.03); -fx-min-width: 480;">
        <padding>
            <Insets top="60" right="60" bottom="60" left="60"/>
        </padding>

        <StackPane maxWidth="120" maxHeight="120">
            <Circle radius="60" style="-fx-fill: rgba(46,109,164,0.15); -fx-stroke: rgba(46,109,164,0.3); -fx-stroke-width: 2;"/>
            <Circle radius="40" style="-fx-fill: rgba(46,109,164,0.25); -fx-stroke: rgba(46,109,164,0.4); -fx-stroke-width: 1;"/>
            <Label text="🌿" style="-fx-font-size: 48px;"/>
        </StackPane>

        <Region prefHeight="16"/>

        <Label text="Serenity"
               style="-fx-text-fill: #FFFFFF; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
        <Label text="Mental Health Therapy Center"
               style="-fx-text-fill: #8AAACF; -fx-font-size: 16px; -fx-font-family: 'Georgia';"/>

        <Region prefHeight="24"/>

        <Separator style="-fx-background-color: rgba(255,255,255,0.08);" maxWidth="200"/>

        <Region prefHeight="12"/>

        <Label text="Join our team and make a difference."
               style="-fx-text-fill: #5A7A9A; -fx-font-size: 13px; -fx-font-style: italic; -fx-font-family: 'Georgia';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>

        <Label text="Create your account to get started."
               style="-fx-text-fill: #4A6B8A; -fx-font-size: 11px; -fx-font-family: 'Georgia';"
               wrapText="true" maxWidth="300" alignment="CENTER"/>
    </VBox>

    <!-- ═══════════ RIGHT REGISTRATION PANEL ═══════════ -->
    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-min-width: 560;">
        <padding>
            <Insets top="20" right="60" bottom="20" left="60"/>
        </padding>

        <!-- Registration Card -->
        <VBox alignment="CENTER" spacing="4" maxWidth="460"
              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 30, 0, 0, 10);">
            <padding>
                <Insets top="32" right="40" bottom="28" left="40"/>
            </padding>

            <!-- Header -->
            <Label text="Create Account"
                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Fill in your details to register"
                   style="-fx-text-fill: #6A8AAA; -fx-font-size: 12px;"/>

            <Region prefHeight="16"/>

            <!-- Scrollable form area -->
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
                        maxHeight="520" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
                <VBox spacing="3">
                    <padding>
                        <Insets top="4" right="8" bottom="4" left="4"/>
                    </padding>

                    <!-- Full Name -->
                    <Label text="FULL NAME" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1;"/>
                    <TextField fx:id="txtFullName" promptText="Enter your full name"
                               style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #5A7A9A; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                    <Label fx:id="lblFullNameError" text="" style="-fx-font-size: 10px;"/>

                    <!-- Email -->
                    <Label text="EMAIL" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1;"/>
                    <TextField fx:id="txtEmail" promptText="Enter your email address"
                               style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #5A7A9A; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                    <Label fx:id="lblEmailError" text="" style="-fx-font-size: 10px;"/>

                    <!-- Username -->
                    <Label text="USERNAME" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1;"/>
                    <TextField fx:id="txtUsername" promptText="Choose a username"
                               style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #5A7A9A; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                    <Label fx:id="lblUsernameError" text="" style="-fx-font-size: 10px;"/>

                    <!-- Password row -->
                    <HBox spacing="12">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="PASSWORD" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1;"/>
                            <PasswordField fx:id="txtPassword" promptText="Min 6 characters"
                                           style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #5A7A9A; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                            <Label fx:id="lblPasswordError" text="" style="-fx-font-size: 10px;"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="CONFIRM PASSWORD" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1;"/>
                            <PasswordField fx:id="txtConfirmPassword" promptText="Repeat password"
                                           style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #5A7A9A; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                            <Label fx:id="lblConfirmPasswordError" text="" style="-fx-font-size: 10px;"/>
                        </VBox>
                    </HBox>

                    <Region prefHeight="4"/>
                    <Separator style="-fx-background-color: rgba(255,255,255,0.06);"/>
                    <Region prefHeight="2"/>

                    <Label text="SECURITY QUESTION" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1;"/>
                    <ComboBox fx:id="cmbSecurityQuestion" promptText="Select a security question" maxWidth="Infinity"/>
                    <Label fx:id="lblSecurityQuestionError" text="" style="-fx-font-size: 10px;"/>

                    <Label text="SECURITY ANSWER" style="-fx-text-fill: #8AAACF; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1;"/>
                    <TextField fx:id="txtSecurityAnswer" promptText="Your answer (case-insensitive)"
                               style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #5A7A9A; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                    <Label fx:id="lblSecurityAnswerError" text="" style="-fx-font-size: 10px;"/>
                </VBox>
            </ScrollPane>

            <Region prefHeight="6"/>

            <!-- Message -->
            <Label fx:id="lblMessage" text="" wrapText="true" maxWidth="Infinity" alignment="CENTER"
                   style="-fx-font-size: 12px;"/>

            <!-- Register Button -->
            <Button text="Create Account" onAction="#handleRegister" maxWidth="Infinity" mnemonicParsing="false"
                    style="-fx-background-color: linear-gradient(to right, #2E6DA4, #1A4F7A); -fx-text-fill: #FFFFFF; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 14; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(46,109,164,0.4), 10, 0, 0, 4);"/>

            <Region prefHeight="10"/>

            <!-- Back to Login -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Already have an account?" style="-fx-text-fill: #5A7A9A; -fx-font-size: 12px;"/>
                <Hyperlink text="Sign In" onAction="#handleBackToLogin"
                           style="-fx-text-fill: #5BB8D4; -fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
